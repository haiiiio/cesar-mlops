# CESAR Prediction API. Mount artifact_storage or set CESAR_MODEL_PATH / CESAR_CONTRACT_PATH at runtime.
FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir fastapi "uvicorn[standard]" pydantic joblib scikit-learn numpy

COPY prediction_contract/ /app/prediction_contract/
COPY runtime/ /app/runtime/

ENV PYTHONPATH=/app

EXPOSE 8000

CMD ["uvicorn", "runtime.prediction_api.app:app", "--host", "0.0.0.0", "--port", "8000"]
