# CESAR Rating UI. Serve static build; proxy /api to API in production or set CESAR_API_BASE.
FROM node:20-alpine AS build

WORKDIR /app
COPY runtime/rating_ui/ ./

RUN npm install && npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
